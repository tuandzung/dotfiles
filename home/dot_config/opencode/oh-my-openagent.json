{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "zai-coding-plan/glm-5.1",
      "fallback_models": [
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        }
      ]
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "librarian": {
      "model": "google/gemini-3-flash-preview"
    },
    "explore": {
      "model": "google/gemini-3.1-flash-lite-preview",
      "variant": "default",
      "fallback_models": [
        {
          "model": "github-copilot/grok-code-fast-1"
        }
      ]
    },
    "multimodal-looker": {
      "model": "zai-coding-plan/glm-5v-turbo",
      "fallback_models": [
        {
          "model": "zai-coding-plan/glm-4.6v"
        },
        {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        }
      ]
    },
    "prometheus": {
      "model": "zai-coding-plan/glm-5.1"
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "zai-coding-plan/glm-5.1"
    },
    "sisyphus-junior": {
      "model": "zai-coding-plan/glm-5-turbo"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "zai-coding-plan/glm-5v-turbo"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "quick": {
      "model": "github-copilot/gpt-5.4-mini",
      "variant": "medium"
    },
    "unspecified-low": {
      "model": "github-copilot/gpt-5.4-mini",
      "variant": "medium"
    },
    "unspecified-high": {
      "model": "zai-coding-plan/glm-5.1"
    },
    "writing": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "artistry": { "model": "zai-coding-plan/glm-5v-turbo" }
  }
}
