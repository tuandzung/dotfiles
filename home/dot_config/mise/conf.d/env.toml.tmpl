[env]
{{-   $top := deepCopy . }}
{{-   $top = merge $top (dict "personal" (dict "scope" "global")) }}
{{-   template "mise/env_git.toml.tmpl" $top }}
{{- range .decryptEnterprise }}
{{-   $top := deepCopy $ }}
{{-   $top = merge $top (dict "enterprise" (dict "name" . "scope" "global")) }}
{{-   template "mise/env_git.toml.tmpl" $top }}
{{- end }}
