{{- $chezmoiData := deepCopy . -}}
{{- $chezmoiData = unset $chezmoiData "chezmoi" -}}

{{- $sourceDir := joinPath .chezmoi.workingTree "root" -}}
sourceDir: {{ $sourceDir }}

destDir: /

encryption: age
format: yaml
mode: symlink

# Uncomment the following line to set umask for MacOS root system
# umask: 0o02

add:
  templateSymlinks: true

diff:
  pager: delta --pager="ov -F --section-delimiter '^(added:|removed:|renamed:|Δ)' --section-header --pattern '•'"

data:
  non_root_user: {{ .chezmoi.username }}
  {{- $chezmoiData | toYaml | nindent 2 }}

age:
  identities:
    - {{ .chezmoi.homeDir }}/.config/chezmoi/personal
    {{-  range $chezmoiData.decryptEnterprise }}
    - {{ $.chezmoi.homeDir }}/.config/chezmoi/enterprise_{{ . }}
    {{-  end }}
  recipients:
    - 
    {{- range $chezmoiData.decryptEnterprise }}
    {{-   if eq . "TCV" }}
    - 
    {{-   end }}
    {{- end }}
