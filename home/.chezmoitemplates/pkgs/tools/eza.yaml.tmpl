name: eza
is_essential: true
{{- if eq .chezmoi.os "darwin" }}
method: os
macos:
  packages:
    - name: eza
{{- else }}
method: binary
github:
  repo: eza-community/eza
  version: latest
  {{- $arch := "" }}
  {{- if eq .chezmoi.arch "amd64" }}
  {{-   $arch = "x86_64" }}
  {{- else if eq .chezmoi.arch "arm64" }}
  {{-   $arch = "aarch64" }}
  {{- end }}
  release_asset: eza_{{ $arch }}-unknown-linux-gnu.tar.gz
archive:
  - path: eza
hook:
  after: |-
    curl -fsSL https://raw.githubusercontent.com/eza-community/eza/refs/heads/main/completions/fish/eza.fish -o {{ .chezmoi.homeDir }}/.config/fish/completions/eza.fish
{{- end }}
