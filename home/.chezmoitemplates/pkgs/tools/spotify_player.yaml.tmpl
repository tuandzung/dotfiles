{{- if .hasSound }}
name: spotify_player
is_essential: true
{{- if eq .osid "linux-arch" "darwin" }}
method: os
macos:
  packages:
    - name: spotify_player
arch:
  packages:
    - name: spotify-player-full
{{- else }}
method: shell
dependencies:
  - rust
content: |-
  cargo install spotify_player --no-default-features --locked --features pulseaudio-backend,streaming,notify
{{- end }}
{{- end }}
