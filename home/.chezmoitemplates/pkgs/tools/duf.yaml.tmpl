name: duf
{{- if eq .osid "linux-arch" "darwin" }}
method: os
macos:
  packages:
    - name: duf
arch:
  packages:
    - name: duf
{{- else }}
method: binary
github:
  repo: muesli/duf
  version: latest
  {{- $os := "" }}
  {{- if eq .chezmoi.os "darwin" }}
  {{-   $os = "darwin" }}
  {{- else if eq .chezmoi.os "linux" "android" }}
  {{-   $os = "linux" }}
  {{- end }}
  {{- $arch := "" }}
  {{- if eq .chezmoi.arch "amd64" }}
  {{-   $arch = "x86_64" }}
  {{- else if eq .chezmoi.arch "arm64" }}
  {{-   $arch = "arm64" }}
  {{- end }}
  release_asset: duf_%s_{{ $os }}_{{ $arch }}.tar.gz
archive:
  - path: duf
{{- end }}
