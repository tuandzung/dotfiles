name: just
{{- if and (eq .chezmoi.os "linux") }}
method: binary
github:
  repo: casey/just
  {{- $arch := "" }}
  {{- if eq .chezmoi.arch "amd64" }}
  {{- $arch = "x86_64" }}
  {{- else if eq .chezmoi.arch "arm64" }}
  {{- $arch = "aarch64" }}
  {{- end }}
  release_asset: just-%s-{{ $arch }}-unknown-linux-musl.tar.gz
archive:
  - path: just
  - path: just.1
    location: {{ .chezmoi.homeDir }}/.local/man/man1
  - path: completions/just.fish
    location: {{ .chezmoi.homeDir }}/.config/fish/completions
    strip: 1
{{- else }}
method: os
macos:
  packages:
    - name: just
{{- end }}
