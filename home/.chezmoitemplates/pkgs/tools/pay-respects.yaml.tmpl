name: pay-respects
method: binary
github:
  repo: iffse/pay-respects
  {{- $os := "" }}
  {{- $arch := "" }}
  {{- if eq .chezmoi.os "darwin" }}
  {{- $os = "apple-darwin" }}
  {{- else if eq .chezmoi.os "linux" }}
  {{- $os = "unknown-linux-musl" }}
  {{- end }}
  {{- if eq .chezmoi.arch "amd64" }}
  {{- $arch = "x86_64" }}
  {{- else if eq .chezmoi.arch "arm64" }}
  {{- $arch = "aarch64" }}
  {{- end }}
  release_asset: pay-respects-%s-{{ $arch }}-{{ $os }}.tar.zst
archive:
  - path: pay-respects
  - path: _pay-respects-fallback-100-request-ai
  - path: _pay-respects-module-100-runtime-rules
  - path: man/*.1
    strip: 1
    location: {{ .chezmoi.homeDir }}/.local/man/man1
  - path: man/*.5
    strip: 1
    location: {{ .chezmoi.homeDir }}/.local/man/man5
