name: glow
method: binary
github:
  repo: charmbracelet/glow
  {{- $os := "" }}
  {{- if eq .chezmoi.os "darwin" }}
  {{-   $os = "Darwin" }}
  {{- else if eq .chezmoi.os "linux" "android" }}
  {{-   $os = "Linux" }}
  {{- end }}
  {{- $arch := "" }}
  {{- if eq .chezmoi.arch "amd64" }}
  {{-   $arch = "x86_64" }}
  {{- else if eq .chezmoi.arch "arm64" }}
  {{-   $arch = "arm64" }}
  {{- end }}
  release_asset: glow_%s_{{ $os }}_{{ $arch }}.tar.gz
archive:
  - path: glow_%s_{{ $os }}_{{ $arch }}/glow
    strip: 1
  - path: glow_%s_{{ $os }}_{{ $arch }}/completions/glow.fish
    strip: 2
    location: {{ .chezmoi.homeDir }}/.config/fish/completions
