name: zoxide
is_essential: true
{{- if eq .osid "linux-arch" "darwin" }}
method: os
macos:
  packages:
    - name: zoxide
arch:
  packages:
    - name: zoxide
{{- else }}
method: binary
is_essential: true
github:
  repo: ajeetdsouza/zoxide
  {{- if eq .chezmoi.arch "amd64" }}
  release_asset: zoxide-%s-x86_64-unknown-linux-musl.tar.gz
  {{- else if eq .chezmoi.arch "arm64" }}
  release_asset: zoxide-%s-aarch64-unknown-linux-musl.tar.gz
  {{- end }}
archive:
  - path: zoxide
  - path: man/man1/*
    strip: 2
    location: {{ .chezmoi.homeDir }}/.local/man/man1
  - path: completions/zoxide.fish
    strip: 1
    location: {{ .chezmoi.homeDir }}/.config/fish/completions
{{- end }}
