name: rg
is_essential: true
{{- if eq .chezmoi.os "darwin" }}
method: os
# https://repology.org/project/ripgrep/versions
macos:
  packages:
    - name: ripgrep
{{- else }}
method: binary
github:
  repo: BurntSushi/ripgrep
  {{- $arch := "" }}
  {{- $suffix := "" }}
  {{- if eq .chezmoi.arch "amd64" }}
  {{-   $arch = "x86_64" }}
  {{-   $suffix = "musl" }}
  {{- else if eq .chezmoi.arch "arm64" }}
  {{-   $arch = "arm" }}
  {{-   $suffix = "gnu" }}
  {{- end }}
  release_asset: ripgrep-%s-{{ $arch }}-unknown-linux-{{ $suffix }}.tar.gz
archive:
  strip_components: 1
  paths:
    - ripgrep-%s-{{ $arch }}-unknown-linux-{{ $suffix }}/rg
hook:
  after: |
    arch={{ $arch }}
    libc={{ $suffix }}
    param="-xz -f $TEMP_DIR/$RELEASE_ASSET"
    mkdir -p "$MAN_DIR/man1"
    tar $param --strip=2 -C "$MAN_DIR/man1" "ripgrep-%s-$arch-unknown-linux-$libc/doc/rg.1"
{{- end }}
