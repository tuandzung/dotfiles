{{- if ne .chezmoi.os "android" }}
name: docker-compose
method: binary
github:
  repo: docker/compose
  {{- $arch := "" }}
  {{- if eq .chezmoi.arch "amd64" }}
  {{-   $arch = "x86_64" }}
  {{- else if eq .chezmoi.arch "arm64" }}
  {{-   $arch = "aarch64" }}
  {{- end }}
  release_asset: docker-compose-{{ .chezmoi.os }}-{{ $arch }}
  sha256: checksums.txt
hook:
  after: |-
    curl -fSsL https://raw.githubusercontent.com/brgmnn/fish-docker-compose/refs/heads/master/completions/docker-compose.fish
      -o {{ .chezmoi.homeDir }}/.config/fish/completions/docker-compose.fish
{{- end }}
