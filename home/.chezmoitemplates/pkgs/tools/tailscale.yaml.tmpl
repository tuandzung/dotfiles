{{- if eq .kind "pc" "laptop" }}
name: tailscale
method: os
is_essential: true
gentoo:
  packages:
    - name: net-vpn/tailscale
      accept_keywords: |-
        net-vpn/tailscale ~amd64
  hook:
    after: |-
      sudo rc-update add tailscale default
      sudo rc-service tailscale restart
      sudo tailscale up
arch:
  packages:
    - name: tailscale
  hook:
    after: |-
      sudo systemctl enable --now tailscaled
      sudo tailscale up
{{-   if eq .osid "linux-ubuntu" "linux-linuxmint" }}
ubuntu:
  packages:
    - name: tailscale
      repo_name: tailscale
      repo_url: https://pkgs.tailscale.com/stable/ubuntu
      repo_version: {{ .chezmoi.osRelease.ubuntuCodename }} main
      key: https://pkgs.tailscale.com/stable/ubuntu/{{ .chezmoi.osRelease.ubuntuCodename }}.noarmor.gpg
  hook:
    after: |-
      sudo systemctl enable --now tailscaled
      sudo tailscale up
{{-   end }}
{{- end }}
