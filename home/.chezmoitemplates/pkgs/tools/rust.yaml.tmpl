name: rust
is_essential: true
method: os
gentoo:
  packages:
    - name: dev-lang/rust
arch:
  packages:
    - name: rust
macos:
  packages:
    - name: rust
{{- if eq .osid "linux-ubuntu" "linux-linuxmint" }}
ubuntu:
  packages:
    - name: rustup
  hook:
    after: |-
      rustup default stable
{{- end }}
