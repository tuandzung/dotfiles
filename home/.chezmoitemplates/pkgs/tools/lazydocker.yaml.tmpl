name: lazydocker
is_essential: true
{{- if eq .chezmoi.os "linux" }}
method: binary
github:
  repo: jesseduffield/lazydocker
  version: latest
  {{- $os := "" }}
  {{- if eq .chezmoi.os "darwin" }}
  {{-   $os = "Darwin" }}
  {{- else if eq .chezmoi.os "linux" }}
  {{-   $os = "Linux" }}
  {{- end }}
  {{- $arch := "" }}
  {{- if eq .chezmoi.arch "amd64" }}
  {{-   $arch = "x86_64" }}
  {{- else if eq .chezmoi.arch "arm64" }}
  {{-   $arch = "arm64" }}
  {{- end }}
  release_asset: lazydocker_%s_{{ $os }}_{{ $arch }}.tar.gz
  sha256: checksums.txt
archive:
  - path: lazydocker
{{- else }}
method: os
macos:
  packages:
    - name: lazydocker
{{- end }}
