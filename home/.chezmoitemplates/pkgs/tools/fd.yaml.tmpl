name: fd
is_essential: true
{{- if eq .chezmoi.os "android" "darwin" }}
# Use package manager for Android, macOS
method: os
termux:
  packages:
    - name: fd
macos:
  packages:
    - name: fd
{{- else }}
method: binary
github:
  repo: sharkdp/fd
  version: latest
  {{- $arch := "" }}
  {{- if eq .chezmoi.arch "amd64" }}
  {{- $arch = "x86_64" }}
  {{- else if eq .chezmoi.arch "arm64" }}
  {{- $arch = "aarch64" }}
  {{- end }}
  release_asset: fd-%1s-{{ $arch }}-unknown-linux-musl.tar.gz
archive:
archive:
  - path: fd-%1s-{{ $arch }}-unknown-linux-musl/fd
    strip: 1
  - path: fd-%1s-{{ $arch }}-unknown-linux-musl/fd.1
    strip: 1
    location: {{ .chezmoi.homeDir }}/.local/man/man1
  - path: fd-%1s-{{ $arch }}-unknown-linux-musl/autocomplete/fd.fish
    strip: 2
    location: {{ .chezmoi.homeDir }}/.config/fish/completions
{{- end }}
