name: tldr
{{- if eq .osid "linux-arch" "darwin" }}
is_essential: true
method: os
# https://repology.org/project/tealdeer/versions
arch:
  packages:
    - name: tealdeer
macos:
  packages:
    - name: tealdeer
{{- else }}
method: binary
github:
  repo: dbrgn/tealdeer
  {{- $arch := "" }}
  {{- if eq .chezmoi.arch "amd64" }}
  {{-   $arch = "x86_64" }}
  {{- else if eq .chezmoi.arch "arm64" }}
  {{-   $arch = "aarch64" }}
  {{- end }}
  {{- $variant := "" }}
  {{- if eq .chezmoi.os "darwin" }}
  {{-   $variant = printf "macos-%s" $arch }}
  {{- else if eq .chezmoi.os "linux" "android" }}
  {{-   $variant = printf "linux-%s-musl" $arch }}
  {{- end }}
  release_asset: tealdeer-{{ $variant }}
  sha256: tealdeer-{{ $variant }}.sha256
{{- end }}
