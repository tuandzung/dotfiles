name: croc
method: binary
github:
  repo: schollz/croc
  {{- $os := "" }}
  {{- if eq .chezmoi.os "darwin" }}
  {{-   $os = "macOS" }}
  {{- else if eq .chezmoi.os "linux" "android" }}
  {{-   $os = "Linux" }}
  {{- end }}
  {{- $arch := "" }}
  {{- if eq .chezmoi.arch "arm64" }}
  {{-   $arch = "ARM64" }}
  {{- else if eq .chezmoi.arch "amd64" }}
  {{-   $arch = "64bit" }}
  {{- end }}
  release_asset: croc_%1s_{{ $os }}-{{ $arch }}.tar.gz
  sha256: croc_%1s_checksums.txt
archive:
  - path: croc
