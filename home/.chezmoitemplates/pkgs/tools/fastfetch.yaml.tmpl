name: fastfetch
method: os
is_essential: true
gentoo:
  packages:
    - name: app-misc/fastfetch
arch:
  packages:
    - name: fastfetch
ubuntu:
  packages:
    - name: fastfetch
{{- if eq .chezmoi.osRelease.id "ubuntu" "linuxmint" }}
