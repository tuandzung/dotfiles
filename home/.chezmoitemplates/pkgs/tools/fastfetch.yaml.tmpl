      repo_url: https://ppa.launchpadcontent.net/zhangsongcui3371/fastfetch/ubuntu
      repo_version: {{ .chezmoi.osRelease.ubuntuCodename }} main
{{- end }}
macos:
  packages:
    - name: fastfetch
