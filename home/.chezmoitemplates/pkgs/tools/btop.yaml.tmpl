name: btop
is_essential: true
{{- if eq .chezmoi.os "darwin"}}
method: os
macos:
  packages:
    - name: btop
{{- else }}
method: binary
github:
  repo: aristocratos/btop
  version: latest
  {{- if eq .chezmoi.arch "amd64" }}
  release_asset: btop-x86_64-unknown-linux-musl.tar.gz
  {{- else if eq .chezmoi.arch "arm64" }}
  release_asset: btop-aarch64-unknown-linux-musl.tar.gz
  {{- end }}
archive:
  - path: btop/bin/btop
    strip: 2
{{- end }}
