name: rtk
method: binary
github:
  repo: rtk-ai/rtk
  {{- $os := "" }}
  {{- $arch := "" }}
  {{- if eq .chezmoi.os "darwin" }}
  {{- $os = "apple-darwin" }}
  {{- else if eq .chezmoi.os "linux" }}
  {{- $os = "unknown-linux-musl" }}
  {{- end }}
  {{- if eq .chezmoi.arch "amd64" }}
  {{- $arch = "x86_64" }}
  {{- else if eq .chezmoi.arch "arm64" }}
  {{- $arch = "aarch64" }}
  {{- end }}
  release_asset: rtk-{{ $arch }}-{{ $os }}.tar.gz
  sha256: checksums.txt
archive:
  - path: rtk
