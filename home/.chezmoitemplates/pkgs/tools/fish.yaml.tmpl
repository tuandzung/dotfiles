name: fish
method: os
is_essential: true
gentoo:
  packages:
    - name: app-shells/fish
arch:
  packages:
    - name: fish
{{- if eq .osid "linux-ubuntu" "linux-linuxmint" }}
ubuntu:
  packages:
    - name: fish
      repo_name: fish-shell
      repo_url: https://ppa.launchpadcontent.net/fish-shell/release-4/ubuntu
      repo_version: {{ .chezmoi.osRelease.ubuntuCodename }} main
{{- end }}
{{- if eq .osid "linux-debian" }}
ubuntu:
  packages:
    - name: fish
      repo_name: fish-shell
      repo_url: http://download.opensuse.org/repositories/shells:/fish:/release:/4/Debian_{{ .chezmoi.osRelease.versionID }}/
      repo_version: /
      key: https://download.opensuse.org/repositories/shells:fish:release:4/Debian_{{ .chezmoi.osRelease.versionID }}/Release.key
{{- end }}
termux:
  packages:
    - name: fish
macos:
  packages:
    - name: fish
