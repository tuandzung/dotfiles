# vim:sw=4 sts=4
{{- range .hosts }}
Host {{ .host }}
    {{- if hasKey . "hostname" }}
    Hostname {{ .hostname }}
    {{- end }}
    {{- if hasKey . "port" }}
    Port {{ .port }}
    {{- end }}
    User {{ .user }}
    {{- $algo := "ed25519" }}
    {{- if hasKey . "algo" }}
    {{-   $algo = .algo }}
    {{- end }}
    {{- range .identities }}
    IdentityFile ~/.ssh/keys/{{ . }}_{{ $algo }}
    {{- end }}
    {{- if hasKey . "jump" }}
    {{-   if ne .jump $.code }}
    ProxyJump {{ .jump }}
    {{-   end }}
    {{- end }}
{{- end }}
